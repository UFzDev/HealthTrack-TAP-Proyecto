<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="ufzdev.HealthTrack.controllers.MainContainerController"
      stylesheets="@../css/global.css, @../css/main.css" prefWidth="1400" prefHeight="900"
      style="-fx-background-color: #f6faf8;">

    <!-- Sidebar: Full Height -->
    <VBox fx:id="sidebar" styleClass="sidebar" spacing="20.0" HBox.hgrow="NEVER">
        <padding>
            <Insets top="30" right="15" bottom="30" left="15"/>
        </padding>

        <Label text="HealthTrack" styleClass="sidebar-logo" />
        <Label text="Community Edition" styleClass="sidebar-subtitle" />

        <Separator styleClass="sidebar-divider"/>

        <VBox spacing="8.0" VBox.vgrow="ALWAYS">
            <Button text="Panel de Control" fx:id="btnHome" onAction="#openHome" styleClass="nav-button" maxWidth="Infinity" />
            <Button text="Mi Perfil" fx:id="btnProfile" onAction="#openProfile" styleClass="nav-button" maxWidth="Infinity" />
            <Button text="Configuración" fx:id="btnSettings" onAction="#openSettings" styleClass="nav-button" maxWidth="Infinity" />
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <Separator styleClass="sidebar-divider"/>
        <Button text="Cerrar Sesión" fx:id="btnLogout" onAction="#handleLogout" styleClass="nav-button-logout" maxWidth="Infinity" />
    </VBox>

    <!-- Main Content Area -->
    <BorderPane HBox.hgrow="ALWAYS">
        <!-- Top bar -->
        <top>
            <HBox styleClass="topbar" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="20" bottom="20" left="30" right="30"/>
                </padding>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="welcomeLabel" text="Bienvenido" styleClass="topbar-welcome" />
                        <Label fx:id="userRoleLabel" text="• Paciente" styleClass="topbar-role-badge" />
                    </HBox>
                    <Label fx:id="dateLabel" text="Lunes, 12 de Mayo" styleClass="topbar-date" />
                </VBox>

                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <!-- Placeholder for notifications or user avatar if needed later -->
                    <Button fx:id="fabRecord" text="+ Nueva Medición" onAction="#handleQuickRecord" styleClass="btn-primary" />
                </HBox>
            </HBox>
        </top>

        <!-- Content area -->
        <center>
            <StackPane>
                <padding>
                    <Insets top="0" right="0" bottom="0" left="0"/>
                </padding>
                <AnchorPane fx:id="contentArea" styleClass="content-area" />
            </StackPane>
        </center>
    </BorderPane>

</HBox>



