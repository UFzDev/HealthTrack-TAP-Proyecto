<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.Region?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="ufzdev.HealthTrack.controllers.LoginController"
      stylesheets="@../css/global.css, @../css/login.css" styleClass="root">

    <VBox styleClass="branding-panel" HBox.hgrow="ALWAYS">
        <VBox spacing="40.0" styleClass="branding-content" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="60" bottom="60" left="60" right="60"/>
            </padding>

            <Label text="HealthTrack Community" styleClass="brand-logo"/>

            <VBox spacing="5.0">
                <Label text="Monitoreo central" styleClass="heading-1"/>
                <Label text="para una vida" styleClass="heading-1"/>
                <Label text="más saludable" styleClass="heading-1"/>
                <Label text="Plataforma colaborativa diseñada para el monitoreo y prevención de enfermedades crónicas como la hipertensión, diabetes y obesidad."
                       styleClass="heading-subtitle" wrapText="true"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="60.0" styleClass="stats-container">
                <VBox>
                    <Label text="Sincronización" styleClass="stat-number"/>
                    <Label text="Firebase" styleClass="stat-label"/>
                </VBox>
                <VBox>
                    <Label text="Reportes Clínicos" styleClass="stat-number"/>
                    <Label text="Exportación" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </VBox>

    <VBox styleClass="login-panel" HBox.hgrow="ALWAYS">
        <VBox spacing="30.0" styleClass="login-container">
            <padding>
                <Insets top="40" bottom="40" left="50" right="50"/>
            </padding>

            <VBox spacing="8.0">
                <Label text="Bienvenido" styleClass="form-title"/>
                <Label text="Ingresa tus credenciales para acceder a tu espacio en HealthTrack"
                       styleClass="form-subtitle" wrapText="true"/>
            </VBox>

            <VBox spacing="20.0">
                <VBox spacing="8.0">
                    <Label text="Nombre de usuario" styleClass="field-label"/>
                    <TextField fx:id="usernameField" promptText="tu_usuario" styleClass="input-field"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Contraseña" styleClass="field-label" HBox.hgrow="ALWAYS"/>
                    <PasswordField fx:id="passwordField" promptText="********" styleClass="input-field"/>
                </VBox>
            </VBox>

            <Button fx:id="btnLogin" text="Iniciar Sesión" onAction="#handleLogin" styleClass="btn-primary" maxWidth="1000"/>
            <Button fx:id="btnTest" text="Test" onAction="#handleLoginTest" styleClass="btn-secondary" maxWidth="1000"/>
            <HBox spacing="5.0" alignment="CENTER">
                <Label text="¿No tienes una cuenta?" styleClass="footer-text"/>
                <Label text="Registrate" styleClass="forgot-link" onMouseClicked="#handleOpenRegister"/>
            </HBox>


            <Button fx:id="btnGit" text="Ver proyecto en GitHub" onAction="#handleOpenGithub" styleClass="btn-tertiary" maxWidth="1000"/>
        </VBox>
    </VBox>
</HBox>
