<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ufzdev.HealthTrack.controllers.admin.AdminUserModalController"
      stylesheets="@../../css/global.css, @../../css/register.css, @../../css/admin/admin.css"
      spacing="20" styleClass="modal-card"
      prefWidth="500" prefHeight="650">
    
    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <VBox spacing="5">
        <Label text="Registro de Personal" styleClass="form-title" />
        <Label text="Complete los datos para dar de alta a un nuevo miembro del equipo." styleClass="context-text" />
    </VBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS">
        <VBox spacing="6">
            <Label text="NOMBRE COMPLETO" styleClass="field-label" />
            <TextField fx:id="nameField" styleClass="input-field" promptText="Nombre y Apellido" />
        </VBox>

        <VBox spacing="6">
            <Label text="USUARIO" styleClass="field-label" />
            <TextField fx:id="usernameField" styleClass="input-field" promptText="ej: dr_garcia" />
        </VBox>

        <VBox spacing="6">
            <Label text="CORREO ELECTRÓNICO" styleClass="field-label" />
            <TextField fx:id="emailField" styleClass="input-field" promptText="correo@healthtrack.com" />
        </VBox>

        <VBox spacing="6">
            <Label text="CONTRASEÑA" styleClass="field-label" />
            <PasswordField fx:id="passwordField" styleClass="input-field" promptText="********" />
        </VBox>

        <VBox spacing="6">
            <Label text="ROL DE ACCESO" styleClass="field-label" />
            <ComboBox fx:id="roleComboBox" styleClass="input-field" maxWidth="Infinity" promptText="Seleccionar Rol" />
        </VBox>
    </VBox>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button fx:id="btnDelete" text="Eliminar Usuario" onAction="#handleDelete" styleClass="btn-danger" visible="false" managed="false" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Cancelar" onAction="#handleCancel" styleClass="btn-tertiary" />
        <Button fx:id="btnSave" text="Guardar Usuario" onAction="#handleSave" styleClass="btn-primary" />
    </HBox>

</VBox>
